# NightmareNet Frontend Environment Variables
# Copy this file to frontend/.env before running the frontend.

# Backend API URL used by the Next.js rewrite proxy
NEXT_API_REWRITE_URL=http://api:8000

# Public API URL used by the frontend for client-side fetches
NEXT_PUBLIC_API_URL=http://localhost:8000

# Build identifier shown in the UI (auto-set by CI)
NEXT_PUBLIC_BUILD_SHA=dev

# Node environment
NODE_ENV=development
