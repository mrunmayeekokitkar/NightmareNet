# NightmareNet Environment Configuration Example
# Copy this file to .env and configure values for your environment

# API Configuration
# Comma-separated list of allowed CORS origins for cross-origin requests.
# Leave unset to block cross-origin requests. Set explicitly for production.
# For local development, use: http://localhost:3000
# Examples:
#   - Single origin: NIGHTMARENET_CORS_ORIGINS=http://localhost:3000
#   - Multiple origins: NIGHTMARENET_CORS_ORIGINS=http://localhost:3000,https://example.com
#   - Allow all: NIGHTMARENET_CORS_ORIGINS=*
NIGHTMARENET_CORS_ORIGINS=http://localhost:3000

# Logging level for the API (debug, info, warning, error)
NIGHTMARENET_LOG_LEVEL=info

# API port (default: 8000)
API_PORT=8000

# Frontend port (default: 3000)
FRONTEND_PORT=3000

# Database configuration (for future hosted platform)
POSTGRES_DB=nightmarenet
POSTGRES_USER=nightmare
POSTGRES_PASSWORD=nightmare
POSTGRES_PORT=5432

# Redis configuration (for future hosted platform)
REDIS_PORT=6379

# Celery worker configuration (for future hosted platform)
CELERY_CONCURRENCY=2
CELERY_LOGLEVEL=info
