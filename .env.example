# NightmareNet Backend & Infrastructure Environment Variables
# Copy this file to .env before running the project.
# Update the values as needed for your local environment.

# API Configuration
# Leave unset to block cross-origin requests. Set explicitly for production.
# Examples:
#   - Single origin: NIGHTMARENET_CORS_ORIGINS=http://localhost:3000
#   - Multiple origins: NIGHTMARENET_CORS_ORIGINS=http://localhost:3000,https://example.com
#   - Allow all: NIGHTMARENET_CORS_ORIGINS=*
NIGHTMARENET_CORS_ORIGINS=http://localhost:3000

# Logging level for the API (debug, info, warning, error)
NIGHTMARENET_LOG_LEVEL=info

# API authentication key (leave empty for local dev if auth is disabled)
NIGHTMARENET_API_KEY=

# PostgreSQL
POSTGRES_DB=nightmarenet
POSTGRES_USER=nightmare
POSTGRES_PASSWORD=nightmare
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# Connection URLs (used by docker-compose services)
NIGHTMARENET_DATABASE_URL=postgresql+psycopg://nightmare:nightmare@db:5432/nightmarenet
NIGHTMARENET_REDIS_URL=redis://redis:6379/0

# Server ports
API_PORT=8000
FRONTEND_PORT=3000

# Celery worker settings
CELERY_CONCURRENCY=2
CELERY_LOGLEVEL=info

# Device selection (auto, cpu, cuda)
NIGHTMARENET_DEVICE=auto
